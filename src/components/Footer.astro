---
import { SITE_TITLE } from '../consts';

const year = new Date().getFullYear();
---

<footer>
  <div class="wrapper">
    <span>© {year} {SITE_TITLE}</span>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
    padding: 1.5rem 0;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--text-muted);
  }
</style>
