---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SOCIAL_LINKS } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={`关于我 · ${SITE_TITLE}`} description="个人介绍" />
  </head>
  <body>
    <Header />
    <main>
      <div class="wrapper">
        <div class="about">
          <div class="avatar-wrap">
            <img src="/avatar.svg" alt="头像" class="avatar" />
          </div>
          <h1>关于我</h1>
          <div class="bio prose">
            <p>
              你好，我是 <strong> April </strong>，互联网 AI PM。
            </p>
            <p>
              这里是我记录想法、分享观察的地方。没有固定主题，关于 AI，关于产品，关于生活，
              只要是让我觉得值得写下来的，都会出现在这里。
            </p>
          </div>
          <div class="social">
            {SOCIAL_LINKS.LinkedIn && (
              <a href={`https://${SOCIAL_LINKS.LinkedIn}`} target="_blank" rel="noopener">
                LinkedIn
              </a>
            )}
          </div>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  .about {
    max-width: 560px;
    padding: 2.5rem 0;
  }

  .avatar-wrap {
    margin-bottom: 1.5rem;
  }

  .avatar {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--border);
    display: block;
  }

  h1 {
    margin-top: 0;
    font-size: 1.75rem;
    margin-bottom: 1rem;
  }

  .bio {
    margin-bottom: 2rem;
  }

  .social {
    display: flex;
    gap: 1.25rem;
    font-family: var(--font-sans);
    font-size: 0.9rem;
  }

  .social a {
    color: var(--text-muted);
    border-bottom: 1px solid var(--border);
    padding-bottom: 1px;
    text-decoration: none;
  }
  .social a:hover {
    color: var(--accent);
    border-color: var(--accent);
    text-decoration: none;
  }
</style>
